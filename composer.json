{
    "name": "sebacarrasco93/laravel-simple-sitemap",
    "description": "Laravel Simple Sitemap",
    "keywords": [
        "Seba Carrasco Poblete",
        "laravel",
        "laravel-simple-sitemap"
    ],
    "homepage": "https://github.com/sebacarrasco93/laravel-simple-sitemap",
    "license": "MIT",
    "authors": [
        {
            "name": "Seba Carrasco Poblete",
            "email": "sebacarrasco93@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^11.0||^12.0||^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.1",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^9.0||^10.0||^11.0",
        "pestphp/pest": "^3.0||^4.0",
        "pestphp/pest-plugin-arch": "^3.0||^4.0",
        "pestphp/pest-plugin-laravel": "^3.0||^4.0",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "SebaCarrasco93\\SimpleSitemap\\": "src/",
            "SebaCarrasco93\\SimpleSitemap\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SebaCarrasco93\\SimpleSitemap\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "clear": "@php vendor/bin/testbench package:purge-laravel-simple-sitemap --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": [
            "@composer run prepare",
            "@php vendor/bin/testbench workbench:build --ansi"
        ],
        "start": [
            "Composer\\Config::disableProcessTimeout",
            "@composer run build",
            "@php vendor/bin/testbench serve"
        ],
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SebaCarrasco93\\SimpleSitemap\\SimpleSitemapServiceProvider"
            ],
            "aliases": {
                "SimpleSitemap": "SebaCarrasco93\\SimpleSitemap\\Facades\\SimpleSitemap"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
